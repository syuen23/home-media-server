# --- User / host ---
# Run `id` on the host to find these. Owner of /mnt/data must match.
PUID=1000 # change this to your user's UID
PGID=2000 # change this to your user's GID
TZ="America/New_York" # change 


# Host path that contains media/ and downloads/ subdirs.
# Must be a single mount so hardlinks work between downloads and library.
CONFIG_DIR=/opt/appdata/config
DATA_ROOT=/srv/media-server/data
# HOST_PATH=/srv/media-server/data/media
# CONTAINER_PATH=/data/media


# --- Gluetun ---
# Setup for nordvpn
VPN_SERVICE_PROVIDER=nordvpn
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=replacewithkey
SERVER_COUNTREIS="United States"
SERVER_CITIES="NEW YORK"


# --- Tailscale ---
# Run `tailscale ip -4` on the host. All service ports bind to this IP only.
TAILSCALE_IP=100.x.y.z


# --- NZBGET ---
NZBGET_USER=user
NZBGET_PASS=pass


# Plex
PLEX_PASS=false # change to false if you do not have plex pass
PLEX_CLAIM=... # enter plex claim token here
PLEXMEDIA=/path/to/your/media/libraries #change
PLEX_ADVERTISE_IP=http://yourServerIP:32400 # change to include your actual IP


# --- Ports ---
NZBGET_PORT=6789
SABNZBD_PORT=8080
SEERR_PORT=5055
PROWLARR_PORT=9696
SONARR_PORT=8989
RADARR_PORT=7878
BAZARR_PORT=6767


# --- Image tags ---
# Pin these before production use. Defaults shown only for quick start.
# Find current versions: https://github.com/linuxserver/docker-<service>/releases
GLUETUN_TAG=latest
NZBGET_TAG=latest
SABNZBD_TAG=latest
PROWLARR_TAG=latest
SONARR_TAG=latest
RADARR_TAG=latest
BAZARR_TAG=latest
PLEX_TAG=latest
SEERR_TAG=latest